# Terraform state files (contain secrets in plaintext)
*.tfstate
*.tfstate.*

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Terraform provider plugins (large, auto-downloaded)
.terraform/

# Terraform lock file (auto-generated, can be committed for reproducibility)
# Uncomment the line below if you do NOT want to commit the lock file
# .terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
